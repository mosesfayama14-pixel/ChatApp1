import java.io.FileWriter;
import java.io.IOException;
import java.util.Random;
import java.util.ArrayList;
import java.util.Scanner;
import java.util.regex.Pattern;

// Message Class
class Message {
    String messageID;
    String messageHash;
    String recipient;
    String content;

    public Message(String id, String hash, String recipient, String content) {
        this.messageID = id;
        this.messageHash = hash;
        this.recipient = recipient;
        this.content = content;
    }
}
//  Main class for application
public class Main {

    // Tracking Collections(storing, sending and disregarding)
    private static final ArrayList<Message> sentMessagesList = new ArrayList<>();
    private static final ArrayList<Message> disregardedMessagesList = new ArrayList<>();
    private static final ArrayList<Message> storedMessagesList = new ArrayList<>();

    // Identity to hold registration data structures
    private static String registeredUser = "";
    private static String registeredPass = "";

    // Global keyboard scanner input tool
    private static final Scanner scanner = new Scanner(System.in);

    public static void main(String[] args) {
        // User Registration Sign Up
        runRegistrationWorkflow();

        // User Login Validation
        boolean loginSuccess = runLoginWorkflow();
        if (!loginSuccess) {
            System.out.println(returnLoginStatus(false));
            return;
        }
        System.out.println(returnLoginStatus(true));

        System.out.println(" Welcome to QuickChat ");

        // Main Loop
        boolean running = true;
        while (running) {
            System.out.println("\nPlease choose one of the following features from the numeric menu:");
            System.out.println("1) Send / Log Messages");
            System.out.println("2) Show recently sent messages");
            System.out.println("3) Stored Messages Menu");
            System.out.println("4) Quit");
            System.out.print("Selection: ");

            String choice = scanner.nextLine().trim();

            if (choice.equals("4")) {
                running = false;
                System.out.println("\nQuitting application safely...");
            } else if (choice.equals("1")) {
                sendMessagesWorkflow();
            } else if (choice.equals("2")) {
                showRecentlySentMessages();
            } else if (choice.equals("3")) {
                runStoredMessagesSubMenu();
            } else {
                System.out.println("\n[INPUT FAULT] Invalid selection. Choose 1, 2, 3, or 4.");
            }
        }
    }

    // --- PART 1 & PART 2 VALIDATION METHODS ---

    public static boolean checkUserName(String username) {
        return username.contains("_") && username.length() <= 5;
    }

    public static boolean checkPasswordComplexity(String password) {
        if (password.length() < 8) return false;

        boolean hasUpper = false;
        boolean hasDigit = false;
        boolean hasSpecial = false;

        for (char ch : password.toCharArray()) {
            if (Character.isUpperCase(ch)) hasUpper = true;
            else if (Character.isDigit(ch)) hasDigit = true;
            else if (!Character.isLetterOrDigit(ch)) hasSpecial = true;
        }
        return hasUpper && hasDigit && hasSpecial;
    }

    public static boolean checkCellPhoneNumber(String cellNumber) {
        String regex = "^\\+?[0-9]{2,4}[0-9]{7,10}$";
        return Pattern.matches(regex, cellNumber.trim()) || cellNumber.trim().length() >= 10;
    }

    public static String registerUser(String username, String password) {
        if (!checkUserName(username)) {
            return "Username is not correctly formatted; please ensure that your username contains an underscore and is no more than five characters in length.";
        }
        if (!checkPasswordComplexity(password)) {
            return "Password is not correctly formatted; please ensure that the password contains at least eight characters, a capital letter, a number, and a special character.";
        }
        return "The two above conditions have been met, and the user has been registered successfully.";
    }

    public static boolean loginUser(String enteredUser, String enteredPass) {
        return enteredUser.equals(registeredUser) && enteredPass.equals(registeredPass);
    }

    public static String returnLoginStatus(boolean success) {
        if (success) {
            return "\nLogin successful! Welcome back.";
        } else {
            return "\n[SECURITY NOTICE] Login failed. Username or password incorrect.";
        }
    }

    // --- WORKFLOW WORKER ENGINES ---

    private static void runRegistrationWorkflow() {
        System.out.println("=== Welcome ====");
        System.out.println("=== System Sign Up ===");

        System.out.print("Enter First Name: ");
        String firstName = scanner.nextLine();

        System.out.print("Enter Last Name: ");
        String lastName = scanner.nextLine();

        // Validate Username Loop
        while (true) {
            System.out.print("Create account username (Must contain '_' & max 5 chars): ");
            String userChoice = scanner.nextLine();
            if (checkUserName(userChoice)) {
                registeredUser = userChoice;
                System.out.println("Username successfully captured.");
                break;
            }
            System.out.println("Username is not correctly formatted; please ensure that your username contains an underscore and is no more than five characters in length.");
        }

        // Validate Password Loop
        while (true) {
            System.out.print("Create account password (8+ chars, upper, digit, special): ");
            String passChoice = scanner.nextLine();
            if (checkPasswordComplexity(passChoice)) {
                registeredPass = passChoice;
                System.out.println("Password successfully captured.");
                break;
            }
            System.out.println("Password is not correctly formatted; please ensure that the password contains at least eight characters, a capital letter, a number, and a special character.");
        }

        System.out.println("\n" + registerUser(registeredUser, registeredPass));
        System.out.println("[REGISTRATION SUCCESS] Welcome " + firstName + " " + lastName + "!");
    }

    private static boolean runLoginWorkflow() {
        System.out.println("\n=== Account Authorization ===");
        System.out.print("Enter username: ");
        String userAttempt = scanner.nextLine();

        System.out.print("Enter password: ");
        String passAttempt = scanner.nextLine();

        return loginUser(userAttempt, passAttempt);
    }

    private static void sendMessagesWorkflow() {
        System.out.print("\nHow many total messages do you want to enter? ");
        String numInput = scanner.nextLine();

        int numMessages;
        try {
            numMessages = Integer.parseInt(numInput.trim());
        } catch (NumberFormatException e) {
            System.out.println("\n[PARSING ERROR] Invalid number parameter. Aborting pipeline.");
            return;
        }

        for (int i = 0; i < numMessages; i++) {
            System.out.println(String.format("\n--- Message Loop %d of %d ---", (i + 1), numMessages));

            // Cellphone check integration
            String recipient = "";
            while (true) {
                System.out.print("Enter mobile number: ");
                recipient = scanner.nextLine();

                if (checkCellPhoneNumber(recipient)) {
                    System.out.println("Cell phone number successfully added.");
                    break;
                }
                System.out.println("Cell phone number incorrectly formatted or does not contain international code.");
            }

            // Length restriction check
            String content = "";
            while (true) {
                System.out.print("Enter descriptive message (Max 250 characters): ");
                content = scanner.nextLine();

                if (content.trim().isEmpty()) {
                    System.out.println("[VALIDATION ERROR] Message text cannot be empty.");
                } else if (content.length() <= 250) {
                    System.out.println("Message text verified.");
                    break;
                } else {
                    System.out.println("[SIZE VIOLATION] Message must be less than 250 characters.");
                }
            }

            Random rand = new Random();
            long idNum = (long) (rand.nextDouble() * 9000000000L) + 1000000000L;
            String messageID = String.valueOf(idNum);
            String hash = generateHash(messageID, i, content);

            int actionChoice = -1;
            while (actionChoice < 1 || actionChoice > 3) {
                System.out.println("\nDefine routing track code selection handling:");
                System.out.println("1) S (Send Message)");
                System.out.println("2) 0 (Disregard Message)");
                System.out.println("3) Store Message");
                System.out.print("Selection (1-3): ");

                try {
                    actionChoice = Integer.parseInt(scanner.nextLine().trim());
                } catch (NumberFormatException e) {
                    actionChoice = -1;
                }
            }

            Message messageInstance = new Message(messageID, hash, recipient, content);

            // Sorting selections based on menu options selected
            if (actionChoice == 1) {
                sentMessagesList.add(messageInstance);
                System.out.println("\n--- Message Sent Successfully ---");
                System.out.println("Message ID: " + messageID);
                System.out.println("Message Hash: " + hash);
                System.out.println("Recipient: " + recipient);
                System.out.println("Message: " + content);
                saveCollectionToJSONFile();
            } else if (actionChoice == 2) {
                disregardedMessagesList.add(messageInstance);
                System.out.println("\n[ROUTING VIEW] Message moved to Disregarded records repository.");
            } else if (actionChoice == 3) {
                storedMessagesList.add(messageInstance);
                System.out.println("\n[BUFFER SYNCH] Message successfully populated inside Stored repository.");
                saveCollectionToJSONFile();
            }
        }
    }

    private static String generateHash(String id, int loopCounter, String content) {
        String cleanID = id.length() >= 2 ? id.substring(0, 2) : "ID";
        String[] splitWords = content.trim().split("\\s+");

        String firstWord = splitWords.length > 0 ? splitWords[0] : "NULL";
        String lastWord = splitWords.length > 0 ? splitWords[splitWords.length - 1] : "NULL";

        return (cleanID + ":" + loopCounter + ":" + firstWord + lastWord).toUpperCase();
    }

    private static void saveCollectionToJSONFile() {
        String jsonFilePath = "messages.json";
        StringBuilder jsonBuilder = new StringBuilder();

        jsonBuilder.append("[\n");
        ArrayList<Message> temporaryCombined = new ArrayList<>();
        temporaryCombined.addAll(sentMessagesList);
        temporaryCombined.addAll(storedMessagesList);

        for (int index = 0; index < temporaryCombined.size(); index++) {
            Message currentMessage = temporaryCombined.get(index);

            jsonBuilder.append("  {\n");
            jsonBuilder.append("    \"messageID\": \"").append(escapeString(currentMessage.messageID)).append("\",\n");
            jsonBuilder.append("    \"messageHash\": \"").append(escapeString(currentMessage.messageHash)).append("\",\n");
            jsonBuilder.append("    \"recipient\": \"").append(escapeString(currentMessage.recipient)).append("\",\n");
            jsonBuilder.append("    \"content\": \"").append(escapeString(currentMessage.content)).append("\"\n");

            if (index < temporaryCombined.size() - 1) {
                jsonBuilder.append("  },\n");
            } else {
                jsonBuilder.append("  }\n");
            }
        }
        jsonBuilder.append("]");

        try (FileWriter diskWriter = new FileWriter(jsonFilePath)) {
            diskWriter.write(jsonBuilder.toString());
            diskWriter.flush();
        } catch (IOException fileWriteException) {
            System.out.println("\n[FILE ERROR] Critical JSON engine file write tracking fault error.");
        }
    }

    private static void showRecentlySentMessages() {
        if (sentMessagesList.isEmpty()) {
            System.out.println("\n[BUFFER STATUS EMPTY] No messages are inside the sent buffers.");
            return;
        }

        System.out.println("\n=== Recently Sent Messages ===");
        for (int idx = 0; idx < sentMessagesList.size(); idx++) {
            Message msg = sentMessagesList.get(idx);
            System.out.printf("[%d] ID: %s | Hash: %s | To: %s | Text: %s%n",
                    (idx + 1), msg.messageID, msg.messageHash, msg.recipient, msg.content);
        }
    }

    // ---- Stored Menu Extension features -----

    private static void runStoredMessagesSubMenu() {
        boolean back = false;
        while (!back) {
            System.out.println("\n=== Stored Messages Search & Analysis Menu ===");
            System.out.println("a) Display sender and recipient of all stored messages");
            System.out.println("b) Display the longest stored message");
            System.out.println("c) Search for a message ID and display details");
            System.out.println("d) Search for all messages stored for a particular recipient");
            System.out.println("e) Delete a message using the message hash");
            System.out.println("f) Display a report that lists full details of all stored messages");
            System.out.println("g) Return to Main Menu");
            System.out.print("Select sub-feature option letter (a-g): ");

            String actionSelection = scanner.nextLine().trim().toLowerCase();

            switch (actionSelection) {
                case "a": displayStoredSendersAndRecipients(); break;
                case "b": displayLongestStoredMessage(); break;
                case "c": searchByMessageID(); break;
                case "d": searchByRecipient(); break;
                case "e": deleteMessageByHash(); break;
                case "f": displayFullStoredReport(); break;
                case "g": back = true; break;
                default: System.out.println("Invalid selection option. Choose letters a through g.");
            }
        }
    }

    private static void displayStoredSendersAndRecipients() {
        if (storedMessagesList.isEmpty()) {
            System.out.println("\nNo messages currently reside in Stored repository.");
            return;
        }
        System.out.println("\n--- Senders and Recipients Stored Registry List ---");
        for (Message msg : storedMessagesList) {
            System.out.println("Sender Username: " + (registeredUser.isEmpty() ? "DefaultUser" : registeredUser) + " -> Recipient Number: " + msg.recipient);
        }
    }

    private static void displayLongestStoredMessage() {
        if (storedMessagesList.isEmpty()) {
            System.out.println("\nNo messages currently reside in Stored repository.");
            return;
        }
        Message longest = storedMessagesList.get(0);
        for (Message msg : storedMessagesList) {
            if (msg.content.length() > longest.content.length()) {
                longest = msg;
            }
        }
        System.out.println("\n--- Longest Tracked Message Item Summary ---");
        System.out.println("Length size: " + longest.content.length() + " characters");
        System.out.println("Message text: " + longest.content);
    }

    private static void searchByMessageID() {
        if (storedMessagesList.isEmpty()) {
            System.out.println("\nNo messages currently reside in Stored repository.");
            return;
        }
        System.out.print("\nEnter tracking Message ID token target search number: ");
        String targetID = scanner.nextLine().trim();

        boolean found = false;
        for (Message msg : storedMessagesList) {
            if (msg.messageID.equals(targetID)) {
                System.out.println("\nTarget Found successfully details registry matching:");
                System.out.println("Recipient phone: " + msg.recipient);
                System.out.println("Message text: " + msg.content);
                found = true;
                break;
            }
        }
        if (!found) System.out.println("No matching record match target instance lookup ID: " + targetID);
    }

    private static void searchByRecipient() {
        if (storedMessagesList.isEmpty()) {
            System.out.println("\nNo messages currently reside in Stored repository.");
            return;
        }
        System.out.print("\nEnter recipient mobile target filter query number: ");
        String targetNumber = scanner.nextLine().trim();

        boolean found = false;
        System.out.println("\n--- Query results for recipient: " + targetNumber + " ---");
        for (Message msg : storedMessagesList) {
            if (msg.recipient.equals(targetNumber)) {
                System.out.printf("-> ID: %s | Hash: %s | Text: %s%n", msg.messageID, msg.messageHash, msg.content);
                found = true;
            }
        }
        if (!found) System.out.println("No records found corresponding to destination phone numbers: " + targetNumber);
    }

    private static void deleteMessageByHash() {
        if (storedMessagesList.isEmpty()) {
            System.out.println("\nNo messages currently reside in Stored repository.");
            return;
        }
        System.out.print("\nEnter the unique Message Hash tag target to delete: ");
        String targetHash = scanner.nextLine().trim().toUpperCase();

        boolean removed = false;
        for (int i = 0; i < storedMessagesList.size(); i++) {
            if (storedMessagesList.get(i).messageHash.equals(targetHash)) {
                storedMessagesList.remove(i);
                System.out.println("\n[SUCCESS] Message with hash " + targetHash + " was dropped from memory pools safely.");
                removed = true;
                saveCollectionToJSONFile();
                break;
            }
        }
        if (!removed) System.out.println("Deletion aborted. No active records contain hash string matching: " + targetHash);
    }

    private static void displayFullStoredReport() {
        if (storedMessagesList.isEmpty()) {
            System.out.println("\nNo messages currently reside in Stored repository.");
            return;
        }
        System.out.println("\n=== Complete System Stored Summary Registry Report ===");
        System.out.println("======================================================");
        for (int idx = 0; idx < storedMessagesList.size(); idx++) {
            Message msg = storedMessagesList.get(idx);
            System.out.printf("Message Index Item Count: #%d%n", (idx + 1));
            System.out.printf("  Message ID    : %s%n", msg.messageID);
            System.out.printf("  Message Hash  : %s%n", msg.messageHash);
            System.out.printf("  To Recipient  : %s%n", msg.recipient);
            System.out.printf("  Content Text  : %s%n", msg.content);
            System.out.println("------------------------------------------------------");
        }
    }

    private static String escapeString(String inputSourceText) {
        if (inputSourceText == null) return "";
        return inputSourceText.replace("\\", "\\\\")
                .replace("\"", "\\\"")
                .replace("\n", "\\n")
                .replace("\r", "\\r")
                .replace("\t", "\\t");
    }
}

