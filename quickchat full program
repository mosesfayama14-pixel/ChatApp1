import java.io.FileWriter;
import java.io.IOException;
import java.util.Random;
import java.util.ArrayList;
import java.util.Scanner;

/**
*
* 
*/
class Message {
String messageID;
String messageHash;
String recipient;
String content;

public Message(String id, String hash, String recipient, String content) {
this.messageID = id;
this.messageHash = hash;
this.recipient = recipient;
this.content = content;
}
}

/**
* Main application class handling registration, authentication,
* message creation, validation, and local JSON persistence via Console.
*/
public class John1{

private static final ArrayList<Message> messageList = new ArrayList<>();
private static int totalMessagesSent = 0;

private static String registeredUser = "";
private static String registeredPass = "";

// Single Scanner instance shared across methods
private static final Scanner scanner = new Scanner(System.in);

public static void main(String[] args) {
// Step 1: User Registration
runRegistrationWorkflow();

// Step 2: User Authentication Login
boolean loginSuccess = runLoginWorkflow();
if (!loginSuccess) {
System.out.println("\n[SECURITY NOTICE] Access Denied.");
return;
}

System.out.println(" Welcome to QuickChat ");

boolean running = true;
while (running) {
System.out.println("\nPlease choose one of the following features from the numeric menu:");
System.out.println("1) Send Messages");
System.out.println("2) Show recently sent messages");
System.out.println("3) Quit");
System.out.print("Selection: ");

String choice = scanner.nextLine().trim();

if (choice.equals("3")) {
running = false;
System.out.println("\nQuitting application safely...");
} else if (choice.equals("1")) {
sendMessagesWorkflow();
} else if (choice.equals("2")) {
showRecentlySentMessages();
} else {
System.out.println("\n[INPUT FAULT ERROR] Invalid selection. Choose 1, 2, or 3.");
}
}
}
private static void runRegistrationWorkflow() {
System.out.println("=== Welcome ====");
System.out.println("=== System Sign Up ===");

System.out.print("Enter First Name: ");
String firstName = scanner.nextLine();

System.out.print("Enter Last Name: ");
String lastName = scanner.nextLine();

System.out.print("Create account username: ");
registeredUser = scanner.nextLine();

System.out.print("Create account password: ");
registeredPass = scanner.nextLine();

System.out.println("[REGISTRATION SUCCESS] Welcome " + firstName + " " + lastName + "!");
}

private static boolean runLoginWorkflow() {
System.out.println("=== Account Authorization ===");

System.out.print("Enter username: ");
String userAttempt = scanner.nextLine();

System.out.print("Enter password: ");
String passAttempt = scanner.nextLine();

return userAttempt.equals(registeredUser) && passAttempt.equals(registeredPass);
}

private static void sendMessagesWorkflow() {
System.out.print("\nHow many total messages do you wish to enter? ");
String numInput = scanner.nextLine();

int numMessages;
try {
numMessages = Integer.parseInt(numInput.trim());
} catch (NumberFormatException e) {
System.out.println("\n[PARSING VALUE ERROR] Invalid integer parameter entered. Aborting pipeline.");
return;
}

for (int i = 0; i < numMessages; i++) {
System.out.println(String.format("\n--- Message Loop %d of %d ---", (i + 1), numMessages));

// 1. Recipient Validation (Minimum 10 characters)
String recipient = "";
while (true) {
System.out.print("Enter recipient mobile number ( international dialing codes): ");
recipient = scanner.nextLine();

if (recipient.trim().length() >= 10) {
break;
}
System.out.println("[FORMAT DATA FAULT] Format verification failure. Full international digits required.");
}

// 2. Message Length Validation (Cap-size <= 250 characters)
String content = "";
while (true) {
System.out.print("Enter short descriptive message (Strict 250 character cap limit): ");
content = scanner.nextLine();

if (content.trim().isEmpty()) {
System.out.println("[VALIDATION ERROR] Message text cannot be empty.");
} else if (content.length() <= 250) {
System.out.println("Message text verified.");
break;
} else {
System.out.println("[TEXT FIELD SIZE VIOLATION] Please enter a message of less than 250 characters.");
}
}

// 3. Generate Unique 10-Digit Message ID Token
Random rand = new Random();
long idNum = (long) (rand.nextDouble() * 9000000000L) + 1000000000L;
String messageID = String.valueOf(idNum);

// 4. Generate Token Hash
String hash = generateHash(messageID, i, content);

// 5. Select Processing Vector Options Direction
int actionChoice = -1;
while (actionChoice < 0 || actionChoice > 2) {
System.out.println("\nDefine routing track code selection handling for this processing instance:");
System.out.println("0) S (Send Message)");
System.out.println("1) 0 (Disregard Message)");
System.out.println("2) Store Message");
System.out.print("Selection (0-2): ");

try {
actionChoice = Integer.parseInt(scanner.nextLine().trim());
} catch (NumberFormatException e) {
actionChoice = -1;
}

if (actionChoice < 0 || actionChoice > 2) {
System.out.println("Invalid selection. Please enter 0, 1, or 2.");
}
}

if (actionChoice == 0) {
// Send Message
Message messageInstance = new Message(messageID, hash, recipient, content);
messageList.add(messageInstance);
totalMessagesSent++;

System.out.println("\n--- Processing Session Sent Details Confirmation Report Sequence ---");
System.out.println("Message ID: " + messageID);
System.out.println("Message Hash: " + hash);
System.out.println("Recipient: " + recipient);
System.out.println("Message: " + content);
System.out.println("---------------------------------------------------------------------");

saveCurrentCollectionToJSONFile();

} else if (actionChoice == 1) {
// Disregard Message
System.out.println("\n[DISCARDING QUEUE ROUTING VIEW] Message discarded safely.");
} else if (actionChoice == 2) {
// Store Message
Message messageInstance = new Message(messageID, hash, recipient, content);
messageList.add(messageInstance);
System.out.println("\n[BUFFER MEMORY SYNCH CONFIRMATION] Message successfully stored in buffer memory.");

saveCurrentCollectionToJSONFile();
}
}

System.out.println("\n=== TASK SUMMARY REPORT ===");
System.out.println("Total messages processed/sent: " + totalMessagesSent);
}

private static String generateHash(String id, int loopCounter, String content) {
String cleanID = id.substring(0, 2);
String[] splitWords = content.trim().split("\\s+");

String firstWord = splitWords.length > 0 ? splitWords[0] : "NULL";
String lastWord = splitWords.length > 0 ? splitWords[splitWords.length - 1] : "NULL";

String generatedRaw = cleanID + ":" + loopCounter + ":" + firstWord + lastWord;
return generatedRaw.toUpperCase();
}

private static void saveCurrentCollectionToJSONFile() {
String jsonFilePath = "messages.json";
StringBuilder jsonBuilder = new StringBuilder();

jsonBuilder.append("[\n");
for (int index = 0; index < messageList.size(); index++) {
Message currentMessage = messageList.get(index);

jsonBuilder.append(" {\n");
jsonBuilder.append(" \"messageID\": \"").append(escapeString(currentMessage.messageID)).append("\",\n");
jsonBuilder.append(" \"messageHash\": \"").append(escapeString(currentMessage.messageHash)).append("\",\n");
jsonBuilder.append(" \"recipient\": \"").append(escapeString(currentMessage.recipient)).append("\",\n");
jsonBuilder.append(" \"content\": \"").append(escapeString(currentMessage.content)).append("\"\n");

if (index < messageList.size() - 1) {
jsonBuilder.append(" },\n");
} else {
jsonBuilder.append(" }\n");
}
}
jsonBuilder.append("]");

try (FileWriter diskWriter = new FileWriter(jsonFilePath)) {
diskWriter.write(jsonBuilder.toString());
diskWriter.flush();
System.out.println("Console Logs: Successfully synchronized records inside messages.json.");
} catch (IOException fileWriteException) {
System.out.println("\n[FILE STORAGE SYSTEM ERROR] Critical persistence pipeline error handling standard file systems operations.");
fileWriteException.printStackTrace();
}
}

private static void showRecentlySentMessages() {
if (messageList.isEmpty()) {
System.out.println("\n[BUFFER STATUS EMPTY] No messages are currently stored inside system buffers.");
return;
}

System.out.println("\n=== Recently Handled Messages Log ===");
for (int idx = 0; idx < messageList.size(); idx++) {
Message msg = messageList.get(idx);
System.out.printf("[%d] ID: %s%n Hash: %s%n To: %s%n Text: %s%n%n",
(idx + 1), msg.messageID, msg.messageHash, msg.recipient, msg.content);
}
}

private static String escapeString(String inputSourceText) {
if (inputSourceText == null) return "";
return inputSourceText.replace("\\", "\\\\")
.replace("\"", "\\\"")
.replace("\n", "\\n")
.replace("\r", "\\r")
.replace("\t", "\\t");
}
}
